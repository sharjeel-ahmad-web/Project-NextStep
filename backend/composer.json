{
    "name": "nextstep/backend",
    "type": "project",
    "description": "NextStep AI Backend - Laravel 11 + MongoDB",
    "keywords": [
        "laravel",
        "mongodb",
        "ai",
        "learning"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.12",
        "mongodb/laravel-mongodb": "^4.3",
        "phpoffice/phpword": "^1.4",
        "smalot/pdfparser": "^2.12"
    },
    "require-dev": {
        "laravel/sail": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "vercel": [
            "php -r \"mkdir('bootstrap/cache', 0777, true);\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "ext-mongodb": "1.21.0",
            "ext-gd": "8.3.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/sail"
            ]
        }
    }
}
